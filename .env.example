# Application
APP_NAME=RobinhoodAICopilot
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-here-change-in-production

# Database (SQLite for local dev, PostgreSQL for staging/production)
DATABASE_URL=sqlite+aiosqlite:///./robinhood_ai.db
DATABASE_URL_SYNC=sqlite:///./robinhood_ai.db
# For PostgreSQL (staging/production):
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/robinhood_ai
# DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/robinhood_ai

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Auth
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Encryption Key (Fernet) - generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# Robinhood
ROBINHOOD_CLIENT_ID=
ROBINHOOD_DEVICE_TOKEN=

# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Market Data
POLYGON_API_KEY=
YAHOO_FINANCE_FALLBACK=true

# LLM (future use)
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
